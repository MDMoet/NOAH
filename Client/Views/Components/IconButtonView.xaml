<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Client.Views.Components.IconButtonView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:Client.Behaviors">

    <Border x:Name="ButtonBorder"
            Padding="{Binding ButtonPadding, Source={x:Reference Root}}"
            HorizontalOptions="Fill"
            VerticalOptions="Fill">
        <Border.Behaviors>
            <behaviors:TapScaleBehavior />
        </Border.Behaviors>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Command, Source={x:Reference Root}}" />
        </Border.GestureRecognizers>
        <Image x:Name="IconImage"
               Source="{Binding IconSource, Source={x:Reference Root}}"
               WidthRequest="{Binding IconWidth, Source={x:Reference Root}}"
               HeightRequest="{Binding IconHeight, Source={x:Reference Root}}"
               Aspect="AspectFit"
               HorizontalOptions="Center"
               VerticalOptions="Center" />
    </Border>
</ContentView>