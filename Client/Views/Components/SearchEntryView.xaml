<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Client.Views.Components.SearchEntryView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border x:Name="FieldBorder"
            HeightRequest="{Binding ControlHeight, Source={x:Reference Root}}"
            BackgroundColor="{Binding FieldBackgroundColor, Source={x:Reference Root}}"
            Stroke="{Binding FieldBorderColor, Source={x:Reference Root}}"
            StrokeThickness="{Binding FieldBorderThickness, Source={x:Reference Root}}"
            Padding="{Binding FieldPadding, Source={x:Reference Root}}">
        <Grid x:Name="FieldLayout"
              ColumnDefinitions="Auto,*"
              VerticalOptions="Center">
            <Image x:Name="IconImage"
                   Source="{Binding IconSource, Source={x:Reference Root}}"
                   IsVisible="{Binding ShowIcon, Source={x:Reference Root}}"
                   WidthRequest="{Binding IconWidth, Source={x:Reference Root}}"
                   HeightRequest="{Binding IconHeight, Source={x:Reference Root}}"
                   Aspect="AspectFit"
                   Opacity="{Binding IconOpacity, Source={x:Reference Root}}"
                   VerticalOptions="Center" />
            <Entry Grid.Column="1"
                   VerticalOptions="Center"
                   HorizontalOptions="Fill"
                   Text="{Binding Text, Source={x:Reference Root}, Mode=TwoWay}"
                   ReturnCommand="{Binding ReturnCommand, Source={x:Reference Root}}"
                   Placeholder="{Binding Placeholder, Source={x:Reference Root}}"
                   PlaceholderColor="{Binding PlaceholderColor, Source={x:Reference Root}}"
                   TextColor="{Binding EntryTextColor, Source={x:Reference Root}}"
                   BackgroundColor="Transparent"
                   FontSize="{Binding FontSize, Source={x:Reference Root}}"
                   HeightRequest="{Binding EntryHeight, Source={x:Reference Root}}" />
        </Grid>
    </Border>
</ContentView>