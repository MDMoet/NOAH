<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Client.Views.ChatAdaptiveView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:Client.Behaviors"
    xmlns:components="clr-namespace:Client.Views.Components"
    xmlns:models="clr-namespace:Client.Models"
    xmlns:views="clr-namespace:Client.Views"
    xmlns:viewmodels="clr-namespace:Client.ViewModels"
    x:DataType="viewmodels:HomeViewModel"
    BackgroundColor="{StaticResource NoahBackground}">

    <Grid x:Name="RootGrid">
        <Grid.Behaviors>
            <behaviors:AdaptiveStateBehavior Breakpoint="720" MobileState="MobileState" DesktopState="DesktopState" />
        </Grid.Behaviors>

        <!-- Desktop layout -->
        <Grid x:Name="DesktopLayout" IsVisible="False">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding DesktopHomeSidebarWidth}" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border BackgroundColor="{StaticResource NoahSurface}"
                        Stroke="#2B2142"
                        StrokeThickness="0.6"
                        Padding="14,12">
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                        <views:DesktopNavigationView IsChatSelected="{Binding IsChatOpen}"
                                                     ShowSettings="False"
                                                     NavigateHomeCommand="{Binding NavigateHomeCommand}"
                                                     NavigateMileageCommand="{Binding NavigateMileageCommand}"
                                                     NavigateNotesCommand="{Binding NavigateNotesCommand}"
                                                     NavigateCalendarCommand="{Binding NavigateCalendarCommand}"
                                                     NavigateChatCommand="{Binding NavigateChatCommand}"
                                                     ToggleSettingsCommand="{Binding ToggleSettingsCommand}"
                                                     HeightRequest="38" />

                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,24,0,18">
                            <Image Source="note_edit_outline.png" WidthRequest="18" HeightRequest="18" Aspect="AspectFit" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Create new chat" FontSize="11" FontFamily="OpenSansSemibold" FontAttributes="Bold" TextColor="{StaticResource NoahAccent}" VerticalOptions="Center" />
                        </Grid>

                        <components:SearchEntryView Grid.Row="2"
                                                    Text="{Binding ChatSearchQuery}"
                                                    Placeholder="Search in chats"
                                                    IconSource="magnify_purple.png"
                                                    IconOpacity="0.7"
                                                    EntryTextColor="{StaticResource NoahTextPrimary}"
                                                    PlaceholderColor="{StaticResource NoahTextMuted}"
                                                    FontSize="12"
                                                    ControlHeight="50"
                                                    EntryHeight="40"
                                                    Margin="0,0,0,22" />

                        <!-- TODO: Replace hardcoded chat history with conversations from the backend. -->
                        <VerticalStackLayout Grid.Row="3" Spacing="9">
                            <Border BackgroundColor="#1A1230" Stroke="{StaticResource NoahAccent}" StrokeThickness="0.7" StrokeShape="RoundRectangle 8" Padding="12,10">
                                <Border.Behaviors>
                                    <behaviors:TapScaleBehavior />
                                </Border.Behaviors>
                                <Label Text="Current chat" FontSize="11" TextColor="{StaticResource NoahTextPrimary}" />
                            </Border>
                            <Border BackgroundColor="#06050A" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,10">
                                <Border.Behaviors>
                                    <behaviors:TapScaleBehavior />
                                </Border.Behaviors>
                                <Label Text="So cool so cool so cool so cool so cool so cool" FontSize="11" TextColor="{StaticResource NoahTextPrimary}" />
                            </Border>
                        </VerticalStackLayout>

                        <views:DesktopNavigationView Grid.Row="4"
                                                     ShowTopNavigation="False"
                                                     IsChatSelected="{Binding IsChatOpen}"
                                                     NavigateHomeCommand="{Binding NavigateHomeCommand}"
                                                     NavigateMileageCommand="{Binding NavigateMileageCommand}"
                                                     NavigateNotesCommand="{Binding NavigateNotesCommand}"
                                                     NavigateCalendarCommand="{Binding NavigateCalendarCommand}"
                                                     NavigateChatCommand="{Binding NavigateChatCommand}"
                                                     ToggleSettingsCommand="{Binding ToggleSettingsCommand}"
                                                     HeightRequest="34" />
                    </Grid>
                </Border>

                <BoxView Grid.Column="1"
                         Color="#171126"
                         WidthRequest="6" />

                <Grid Grid.Column="2" RowDefinitions="*,Auto" BackgroundColor="#030305">
                    <Grid Padding="24,24,24,0">
                        <CollectionView ItemsSource="{Binding ChatMessages}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ChatMessage">
                                    <Grid Padding="0,0,0,16" ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout IsVisible="{Binding IsFromAI}"
                                                             HorizontalOptions="Start"
                                                             MaximumWidthRequest="560"
                                                             Spacing="6">
                                            <Label Text="NOAH"
                                                   FontSize="10"
                                                   TextColor="{StaticResource NoahTextSecondary}" />
                                            <Label Text="{Binding Content}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource NoahTextPrimary}" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                BackgroundColor="{StaticResource NoahAccent}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                Padding="16,10"
                                                MaximumWidthRequest="330"
                                                HorizontalOptions="End"
                                                IsVisible="{Binding IsFromUser}">
                                            <Label Text="{Binding Content}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource NoahTextPrimary}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="56,0,56,14">
                        <Border BackgroundColor="#17122B"
                                StrokeShape="RoundRectangle 999"
                                StrokeThickness="0"
                                Padding="16,0">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <!-- TODO: Connect attachments to file upload when chat messages support files. -->
                                <Image Source="paperclip_purple.png" WidthRequest="26" HeightRequest="16" Aspect="AspectFit" VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Text="{Binding ChatInput}"
                                       Placeholder="Ask me anything."
                                       PlaceholderColor="{StaticResource NoahTextSecondary}"
                                       TextColor="{StaticResource NoahTextPrimary}"
                                       ReturnCommand="{Binding SendChatCommand}"
                                       BackgroundColor="Transparent"
                                       FontSize="12"
                                       HeightRequest="44" />
                                <!-- TODO: Connect camera capture to image upload when chat messages support images. -->
                                <Image Grid.Column="2" Source="camera_outline_purple.png" WidthRequest="17" HeightRequest="17" Aspect="AspectFit" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource NoahAccent}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 999"
                                WidthRequest="44"
                                HeightRequest="44">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SendChatCommand}" />
                            </Border.GestureRecognizers>
                            <Image Source="microphone_outline_dark.png" WidthRequest="22" HeightRequest="22" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Column="2"
                      IsVisible="{Binding IsSettingsOpen}"
                      BackgroundColor="#99000000">
                    <views:SettingsModalView WidthRequest="720"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Mobile layout -->
        <Grid x:Name="MobileLayout" IsVisible="True">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border BackgroundColor="{StaticResource NoahSurface}"
                        StrokeThickness="0"
                        Padding="10,8">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="&#x2630;"
                               FontSize="24"
                               TextColor="{StaticResource NoahAccent}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleChatMenuCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Padding="8,10,8,0"
                      BackgroundColor="#030305">
                    <CollectionView ItemsSource="{Binding ChatMessages}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ChatMessage">
                                <Grid Padding="0,0,0,14" ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout IsVisible="{Binding IsFromAI}"
                                                         HorizontalOptions="Start"
                                                         MaximumWidthRequest="250"
                                                         Spacing="6">
                                        <Label Text="NOAH"
                                               FontSize="10"
                                               TextColor="{StaticResource NoahTextSecondary}" />
                                        <Label Text="{Binding Content}"
                                               FontSize="11"
                                               TextColor="{StaticResource NoahTextPrimary}" />
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource NoahAccent}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="12,8"
                                            MaximumWidthRequest="210"
                                            HorizontalOptions="End"
                                            IsVisible="{Binding IsFromUser}">
                                        <Label Text="{Binding Content}"
                                               FontSize="11"
                                               TextColor="{StaticResource NoahTextPrimary}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <Grid Grid.Row="2"
                      BackgroundColor="#030305">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8"
                          Padding="10,0,8,5">
                        <Border BackgroundColor="#17122B"
                                StrokeShape="RoundRectangle 999"
                                StrokeThickness="0"
                                Padding="16,0">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <!-- TODO: Connect attachments to file upload when chat messages support files. -->
                                <Image Source="paperclip_purple.png"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Text="{Binding ChatInput}"
                                       Placeholder="Ask me anything."
                                       PlaceholderColor="{StaticResource NoahTextSecondary}"
                                       TextColor="{StaticResource NoahTextPrimary}"
                                       ReturnCommand="{Binding SendChatCommand}"
                                       BackgroundColor="Transparent"
                                       FontSize="12"
                                       HeightRequest="44" />
                                <!-- TODO: Connect camera capture to image upload when chat messages support images. -->
                                <Image Grid.Column="2"
                                       Source="camera_outline_purple.png"
                                       WidthRequest="17"
                                       HeightRequest="17"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource NoahAccent}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 999"
                                WidthRequest="44"
                                HeightRequest="44">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SendChatCommand}" />
                            </Border.GestureRecognizers>
                            <!-- TODO: Attach real mic system. -->
                            <Image Source="microphone_outline_dark.png"
                                   WidthRequest="22"
                                   HeightRequest="22"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.RowSpan="3"
                      IsVisible="{Binding IsChatMenuOpen}"
                      ColumnDefinitions="268,*">
                    <Grid Grid.Column="1"
                          BackgroundColor="#66000000">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleChatMenuCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid BackgroundColor="#030305"
                          Padding="12,12,8,10"
                          RowDefinitions="Auto,Auto,Auto,*,Auto">
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="0,0,0,10">
                            <Image Source="cog_outline_purple.png"
                                   WidthRequest="22"
                                   HeightRequest="22"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Start"
                                   VerticalOptions="Center">
                                <Image.Behaviors>
                                    <behaviors:TapScaleBehavior />
                                </Image.Behaviors>
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleSettingsCommand}" />
                                </Image.GestureRecognizers>
                            </Image>
                            <Label Grid.Column="1"
                                   Text="x"
                                   FontSize="24"
                                   TextColor="{StaticResource NoahAccent}"
                                   Padding="10,2"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleChatMenuCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <Border Grid.Row="1"
                                BackgroundColor="#171126"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="9,8"
                                Margin="0,0,0,8">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Source="newchat_purple.png"
                                       WidthRequest="18"
                                       HeightRequest="18"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="Create new chat"
                                       FontSize="11"
                                       TextColor="{StaticResource NoahAccent}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                BackgroundColor="#171126"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="9,8"
                                Margin="0,0,0,12">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Source="magnify_purple.png"
                                       WidthRequest="17"
                                       HeightRequest="17"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="Search in chats"
                                       FontSize="11"
                                       TextColor="{StaticResource NoahTextSecondary}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <VerticalStackLayout Grid.Row="3"
                                             Spacing="8">
                            <Border BackgroundColor="{StaticResource NoahAccent}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="9,8">
                                <Border.Behaviors>
                                    <behaviors:TapScaleBehavior />
                                </Border.Behaviors>
                                <Label Text="Current chat"
                                       FontSize="11"
                                       TextColor="{StaticResource NoahTextPrimary}" />
                            </Border>
                            <Border BackgroundColor="#171126"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="9,8">
                                <Border.Behaviors>
                                    <behaviors:TapScaleBehavior />
                                </Border.Behaviors>
                                <Label Text="So cool so cool so cool so cool so cool"
                                       FontSize="11"
                                       TextColor="{StaticResource NoahTextSecondary}" />
                            </Border>
                        </VerticalStackLayout>

                        <Border Grid.Row="4"
                                HeightRequest="66"
                                StrokeThickness="0"
                                Padding="0">
                            <views:MobileNavigationFooterView IsChatSelected="True"
                                                              NavigateHomeCommand="{Binding NavigateHomeCommand}"
                                                              NavigateMileageCommand="{Binding NavigateMileageCommand}"
                                                              NavigateNotesCommand="{Binding NavigateNotesCommand}"
                                                              NavigateCalendarCommand="{Binding NavigateCalendarCommand}"
                                                              NavigateChatCommand="{Binding NavigateChatCommand}" />
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.RowSpan="3"
                      IsVisible="{Binding IsSettingsOpen}"
                      BackgroundColor="#99000000"
                      Padding="24,116,24,0">
                    <views:SettingsModalView WidthRequest="330"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Start" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Visual states to toggle which layout is visible -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LayoutStates">
                <VisualState x:Name="MobileState">
                    <VisualState.Setters>
                        <Setter TargetName="MobileLayout" Property="IsVisible" Value="True" />
                        <Setter TargetName="DesktopLayout" Property="IsVisible" Value="False" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="DesktopState">
                    <VisualState.Setters>
                        <Setter TargetName="MobileLayout" Property="IsVisible" Value="False" />
                        <Setter TargetName="DesktopLayout" Property="IsVisible" Value="True" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>

</ContentView>
