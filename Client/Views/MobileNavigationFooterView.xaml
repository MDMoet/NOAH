<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Client.Views.MobileNavigationFooterView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:Client.Views.Components">

    <Grid RowDefinitions="1,*" HeightRequest="86" BackgroundColor="Transparent">
        <BoxView HeightRequest="1" BackgroundColor="#17122B" />

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" Padding="8,2,10,4" ColumnSpacing="0">
            <components:IconButtonView HorizontalOptions="Fill" VerticalOptions="Fill" ButtonPadding="5" IsSelected="{Binding IsHomeSelected, Source={x:Reference Root}}" Command="{Binding NavigateHomeCommand, Source={x:Reference Root}}" IconSource="home_outline_purple.png" IconWidth="28" IconHeight="28" IconOpacity="0.50" SelectedIconOpacity="1" SelectedScale="1" SelectedShadowOpacity="0" />
            <components:IconButtonView Grid.Column="1" HorizontalOptions="Fill" VerticalOptions="Fill" ButtonPadding="5" IsSelected="{Binding IsChatSelected, Source={x:Reference Root}}" Command="{Binding NavigateChatCommand, Source={x:Reference Root}}" IconSource="chat_outline_purple.png" IconWidth="28" IconHeight="28" IconOpacity="0.50" SelectedIconOpacity="1" SelectedScale="1" SelectedShadowOpacity="0" />
            <components:IconButtonView Grid.Column="2" HorizontalOptions="Fill" VerticalOptions="Fill" ButtonPadding="5" IsSelected="{Binding IsNotesSelected, Source={x:Reference Root}}" Command="{Binding NavigateNotesCommand, Source={x:Reference Root}}" IconSource="note_outline_purple.png" IconWidth="28" IconHeight="28" IconOpacity="0.50" SelectedIconOpacity="1" SelectedScale="1" SelectedShadowOpacity="0" />
            <components:IconButtonView Grid.Column="3" HorizontalOptions="Fill" VerticalOptions="Fill" ButtonPadding="5" IsSelected="{Binding IsCalendarSelected, Source={x:Reference Root}}" Command="{Binding NavigateCalendarCommand, Source={x:Reference Root}}" IconSource="calendar_purple.png" IconWidth="28" IconHeight="28" IconOpacity="0.50" SelectedIconOpacity="1" SelectedScale="1" SelectedShadowOpacity="0" />
            <components:IconButtonView Grid.Column="4" HorizontalOptions="Fill" VerticalOptions="Fill" ButtonPadding="5" IsSelected="{Binding IsMileageSelected, Source={x:Reference Root}}" Command="{Binding NavigateMileageCommand, Source={x:Reference Root}}" IconSource="counter_purple.png" IconWidth="28" IconHeight="28" IconOpacity="0.50" SelectedIconOpacity="1" SelectedScale="1" SelectedShadowOpacity="0" />
        </Grid>
    </Grid>
</ContentView>
